# ── Minecraft server ────────────────────────────────────────────────────────
MC_HOST=your.minecraft.server.com
MC_PORT=25565
MC_LOG_PATH=/srv/minecraft/server/logs/latest.log

# ── Métriques système ────────────────────────────────────────────────────────
# Dossier hôte à surveiller pour l'espace disque (monté dans le container en lecture seule)
# Exemples : /srv  /home  /opt  /data
SRV_PATH=/srv

# ── Dashboard auth ───────────────────────────────────────────────────────────
ADMIN_PASSWORD=changeme
SECRET_KEY=change-this-to-a-long-random-string

# ── Domain ───────────────────────────────────────────────────────────────────
DOMAIN=localhost

# ── TLS / SSL ────────────────────────────────────────────────────────────────
# Mode 1 (défaut) — self-signed auto, parfait pour LAN/local
#   → Utilise Caddyfile (tls internal), aucune config supplémentaire

# Mode 2 — Let's Encrypt (domaine public, ports 80+443 ouverts)
#   CADDYFILE=Caddyfile.letsencrypt
#   TLS_EMAIL=admin@example.com

# Mode 3 — Certificat existant (wildcard, entreprise…)
#   → Déposer fullchain.pem + privkey.pem dans ./certs/
#   CADDYFILE=Caddyfile.custom
